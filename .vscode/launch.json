{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (SideCar)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/sidecar-app/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
      "preLaunchTask": "dev-server"
    }
  ]
}
